# Required: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: defaults to openai/gpt-4o-mini in lib/config.ts
OPENROUTER_MODEL=openai/gpt-4o-mini

# Evaluator / grader model (OpenRouter)
OPENROUTER_EVAL_MODEL=openai/gpt-4o-mini

# LangSmith (optional — traces disabled if unset)
LANGSMITH_API_KEY=ls__your_key_here
LANGSMITH_PROJECT=llm-eval-playground
LANGSMITH_TRACING=true

# Optional: OpenRouter app attribution (https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://localhost:3000
# OPENROUTER_APP_TITLE=OpenRouter Chat
